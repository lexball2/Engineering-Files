ENVIRONMENT=production

LLM_API_KEY=replace-with-bailian-dashscope-api-key
LLM_BASE_URL=https://replace-with-workspace-id.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-plus
DASHSCOPE_API_KEY=replace-with-bailian-dashscope-api-key
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=knowledge_base_app
MYSQL_PASSWORD=replace-with-database-password
MYSQL_ROOT_PASSWORD=replace-with-root-password-for-local-mysql-container
MYSQL_DATABASE=knowledge_base
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10
MYSQL_SSL_CA=

JWT_SECRET=replace-with-32-byte-or-longer-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=3
JWT_ISSUER=engineering-files-api
JWT_AUDIENCE=engineering-files-web
COOKIE_NAME=kb_access_token
COOKIE_SECURE=true

MILVUS_URI=http://milvus:19530
MILVUS_TOKEN=
MILVUS_SERVER_PEM_PATH=
MILVUS_COLLECTION_NAME=knowledge_base
MILVUS_MINIO_ACCESS_KEY=minioadmin
MILVUS_MINIO_SECRET_KEY=replace-with-milvus-minio-secret
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
IMAGE_COLLECTION_NAME=image_library
IMAGE_TEXT_COLLECTION_NAME=image_text_library
IMAGE_ASSET_TEXT_SCORE_THRESHOLD=0.28
IMAGE_ASSET_SEMANTIC_SCORE_THRESHOLD=0.55

STORAGE_BACKEND=oss
LOCAL_STORAGE_ROOT=data
OSS_REGION=cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=replace-with-private-oss-bucket
OSS_PREFIX=engineering-files/prod
OSS_ACCESS_KEY_ID=replace-with-ram-access-key-id
OSS_ACCESS_KEY_SECRET=replace-with-ram-access-key-secret
OSS_SESSION_TOKEN=

REDIS_PASSWORD=replace-with-redis-password
REDIS_URL=redis://:replace-with-redis-password@redis:6379/0

CORS_ORIGINS=https://example.com,https://www.example.com
TRUSTED_HOSTS=example.com,www.example.com,127.0.0.1,localhost
AUTO_INIT_DB=false
RAG_REQUIRE_DEPARTMENT_MATCH=true

API_RATE_LIMIT_PER_MINUTE=60
EXPENSIVE_RATE_LIMIT_PER_MINUTE=10
MAX_IMAGE_SIZE_MB=15
MAX_IMAGE_PIXELS=40000000
MAX_BATCH_FILES=20
MAX_BATCH_SIZE_MB=200
IMAGE_ASSET_WORKERS=2
MAX_DOCUMENT_SIZE_MB=20
MAX_DOCUMENT_EXPANDED_SIZE_MB=200
MAX_DOCUMENT_TEXT_CHARS=2000000
MAX_MEMORY_SESSIONS=1000
MEMORY_TTL_SECONDS=86400
